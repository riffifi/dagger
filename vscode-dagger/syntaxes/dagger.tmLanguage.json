{
  "name": "Dagger",
  "scopeName": "source.dagger",
  "fileTypes": ["dag"],
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#numbers"},
    {"include": "#directives"},
    {"include": "#keywords"},
    {"include": "#operators"},
    {"include": "#constants"},
    {"include": "#identifiers"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.dagger",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dagger",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {"0": {"name": "punctuation.definition.string.begin.dagger"}},
          "endCaptures": {"0": {"name": "punctuation.definition.string.end.dagger"}},
          "patterns": [
            {"name": "constant.character.escape.dagger", "match": "\\\\."}
          ]
        },
        {
          "name": "string.quoted.single.dagger",
          "begin": "'",
          "end": "'",
          "beginCaptures": {"0": {"name": "punctuation.definition.string.begin.dagger"}},
          "endCaptures": {"0": {"name": "punctuation.definition.string.end.dagger"}},
          "patterns": [
            {"name": "constant.character.escape.dagger", "match": "\\\\."}
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {"name": "constant.numeric.hex.dagger", "match": "\\b0x[0-9A-Fa-f]+\\b"},
        {"name": "constant.numeric.binary.dagger", "match": "\\b0b[01]+\\b"},
        {"name": "constant.numeric.octal.dagger", "match": "\\b0o[0-7]+\\b"},
        {"name": "constant.numeric.float.dagger", "match": "\\b[0-9]+\\.[0-9]+([eE][-+]?[0-9]+)?\\b"},
        {"name": "constant.numeric.float.dagger", "match": "\\b[0-9]+[eE][-+]?[0-9]+\\b"},
        {"name": "constant.numeric.integer.dagger", "match": "\\b[0-9]+\\b"}
      ]
    },
    "directives": {
      "patterns": [
        {"name": "keyword.other.directive.dagger", "match": "\\b@(?:fn|type|burst|static|extern|inline|comptime|private|use|syscall|error|bubble|or|ok|err|break|skip)\\b"}
      ]
    },
    "keywords": {
      "patterns": [
        {"name": "keyword.control.dagger", "match": "\\b(?:loop|fork|block|each|tee|null|true|false)\\b"},
        {"name": "keyword.operator.dagger", "match": "->|=>|::|>>|\\.\\.|\\?|!|&|\\*|=|;|\\[|\\]|\\(|\\)|,|\\."}
      ]
    },
    "constants": {
      "patterns": [
        {"name": "constant.language.dagger", "match": "\\b(?:true|false|null)\\b"}
      ]
    },
    "identifiers": {
      "patterns": [
        {"name": "variable.other.dagger", "match": "\\b[a-zA-Z_][a-zA-Z0-9_.]*\\b"}
      ]
    }
  }
}
